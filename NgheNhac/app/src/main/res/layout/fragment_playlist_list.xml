<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.library.PlaylistListFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlist_list"
        android:layoutAnimation="@anim/layout_animation_fade"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        tools:listitem="@layout/item_playlist" />

    <!-- Empty state (hiển thị khi chưa có playlist nào) -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_library"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize8"
            app:tint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/empty_playlists"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

<!-- FAB tạo playlist mới -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/playlist_create_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/action_create_playlist"
        android:src="@drawable/ic_add"
        app:tint="?attr/colorOnPrimary" />

</FrameLayout>
