<navigation
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:id="@+id/nav_graph"
app:startDestination="@id/libraryFragment" >
<fragment
    android:id="@+id/libraryFragment"
    android:name="com.example.nghenhac.ui.library.LibraryFragment"
    android:label="@string/nav_library"
    tools:layout="@layout/fragment_library" />
<fragment
    android:id="@+id/searchFragment"
    android:name="com.example.nghenhac.ui.search.SearchFragment"
    android:label="@string/nav_search"
    tools:layout="@layout/fragment_search" />
<fragment
    android:id="@+id/settingsFragment"
    android:name="com.example.nghenhac.ui.settings.SettingsFragment"
    android:label="@string/nav_settings"
    tools:layout="@layout/fragment_settings" />

<!--
         Auth: LoginActivity & ProfileActivity are launched as separate Activities,
         not Navigation destinations, to support startActivityForResult pattern
-->

</navigation>